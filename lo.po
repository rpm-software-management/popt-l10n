#: src/popt.c:46
msgid "unknown errno"
msgstr "ລະຫັດຂໍ້ຜິດພາດ (errno) ທີ່ບໍ່ຮູ້ຈັກ"

#: src/popt.c:1200
#, c-format
msgid "option type (%u) not implemented in popt\n"
msgstr "ປະເພດຕົວເລືອກ (%u) ຍັງບໍ່ທັນໄດ້ຕິດຕັ້ງໃຊ້ໃນ popt\n"

#: src/popt.c:1638
msgid "missing argument"
msgstr "ຂາດຄ່າໂຕແປ (argument)"

#: src/popt.c:1640
msgid "option does not take an argument"
msgstr "ຕົວເລືອກນີ້ບໍ່ຕ້ອງການຄ່າໂຕແປ"

#: src/popt.c:1642
msgid "unknown option"
msgstr "ຕົວເລືອກທີ່ບໍ່ຮູ້ຈັກ"

#: src/popt.c:1644
msgid "mutually exclusive logical operations requested"
msgstr "ມີການຮ້ອງຂໍການປະຕິບັດທາງໂລຊິກທີ່ຂັດແຍ້ງກັນ"

#: src/popt.c:1646
msgid "opt->arg should not be NULL"
msgstr "opt->arg ບໍ່ຄວນເປັນຄ່າວ່າງ (NULL)"

#: src/popt.c:1648
msgid "aliases nested too deeply"
msgstr "ຊື່ນາມແຝງ (aliases) ມີການຊ້ອນກັນເລິກເກີນໄປ"

#: src/popt.c:1650
msgid "error in parameter quoting"
msgstr "ຂໍ້ຜິດພາດໃນການໃສ່ເຄື່ອງໝາຍຄຳເວົ້າຂອງພາລາມິເຕີ"

#: src/popt.c:1652
msgid "invalid numeric value"
msgstr "ຄ່າຕົວເລກບໍ່ຖືກຕ້ອງ"

#: src/popt.c:1654
msgid "number too large or too small"
msgstr "ຕົວເລກໃຫຍ່ເກີນໄປ ຫຼື ນ້ອຍເກີນໄປ"

#: src/popt.c:1656
msgid "memory allocation failed"
msgstr "ການຈອງໜ່ວຍຄວາມຈຳລົ້ມເຫຼວ"

#: src/popt.c:1658
msgid "config file failed sanity test"
msgstr "ໄຟລ໌ກຳນົດຄ່າບໍ່ຜ່ານການກວດສອບຄວາມຖືກຕ້ອງ"

#: src/popt.c:1662
msgid "unknown error"
msgstr "ຂໍ້ຜິດພາດທີ່ບໍ່ຮູ້ຈັກ"

#: src/popthelp.c:64 src/popthelp.c:72
msgid "Show this help message"
msgstr "ສະແດງຂໍ້ຄວາມຊ່ວຍເຫຼືອນີ້"

#: src/popthelp.c:65 src/popthelp.c:73
msgid "Display brief usage message"
msgstr "ສະແດງຂໍ້ຄວາມວິທີໃຊ້ແບບຫຍໍ້"

#: src/popthelp.c:76
msgid "Display option defaults in message"
msgstr "ສະແດງຄ່າເລີ່ມຕົ້ນຂອງຕົວເລືອກໃນຂໍ້ຄວາມ"

#: src/popthelp.c:78
msgid "Terminate options"
msgstr "ຢຸດການນຳໃຊ້ຕົວເລືອກ"

#: src/popthelp.c:170
msgid "Help options:"
msgstr "ຕົວເລືອກການຊ່ວຍເຫຼືອ:"

#: src/popthelp.c:171
msgid "Options implemented via popt alias/exec:"
msgstr "ຕົວເລືອກທີ່ຕິດຕັ້ງຜ່ານ popt alias/exec:"

#: src/popthelp.c:179
msgid "NONE"
msgstr "ບໍ່ມີ"

#: src/popthelp.c:181
msgid "VAL"
msgstr "ຄ່າ"

#: src/popthelp.c:185
msgid "INT"
msgstr "ຈຳນວນຖ້ວນ"

#: src/popthelp.c:186
msgid "SHORT"
msgstr "ຈຳນວນຖ້ວນສັ້ນ"

#: src/popthelp.c:187
msgid "LONG"
msgstr "ຈຳນວນຖ້ວນຍາວ"

#: src/popthelp.c:188
msgid "LONGLONG"
msgstr "ຈຳນວນຖ້ວນຍາວຫຼາຍ"

#: src/popthelp.c:189
msgid "STRING"
msgstr "ຂໍ້ຄວາມ"

#: src/popthelp.c:190
msgid "FLOAT"
msgstr "ເລກທົດສະນິຍົມ"

#: src/popthelp.c:191
msgid "DOUBLE"
msgstr "ເລກທົດສະນິຍົມຄວາມລະອຽດສູງ"

#: src/popthelp.c:194
msgid "ARG"
msgstr "ຄ່າໂຕແປ"

#: src/popthelp.c:615
msgid "Usage:"
msgstr "ວິທີໃຊ້:"

#: src/popthelp.c:640
msgid "[OPTION...]"
msgstr "[ຕົວເລືອກ...]"
